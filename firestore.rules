rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================
    // HELPER FUNCTIONS
    // ========================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    // ========================================================
    // SELLERS
    // Fix para "Erro no cadastro - Missing or insufficient permissions"
    // createSeller() escreve diretamente do cliente para sellers/{userId}
    // ========================================================
    match /sellers/{sellerId} {
      // Seller pode ler e atualizar o próprio perfil
      allow read: if isOwner(sellerId);
      // Seller recém-registrado pode criar o próprio documento (userId == auth.uid)
      allow create: if isOwner(sellerId)
                    && request.resource.data.userId == request.auth.uid;
      // Seller pode atualizar o próprio perfil
      allow update: if isOwner(sellerId);
      // Deleção apenas via Admin SDK (server)
      allow delete: if false;
    }

    // ========================================================
    // TENANTS
    // ========================================================
    match /tenants/{tenantId} {
      // Seller lê o próprio tenant
      allow read: if isAuthenticated()
                  && resource.data.ownerId == request.auth.uid;
      // Seller cria o próprio tenant
      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == request.auth.uid;
      // Seller atualiza o próprio tenant
      allow update: if isAuthenticated()
                    && resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    // ========================================================
    // CHECKOUTS
    // Leitura pública: página de checkout carrega produto pelo ID/slug
    // Atualização autenticada: fallback do updateCheckout() no cliente
    // ========================================================
    match /checkouts/{checkoutId} {
      // Público: comprador precisa carregar o checkout pelo ID
      allow read: if true;
      // Fallback de atualização do cliente (seller autenticado)
      allow update: if isAuthenticated();
      // Criação e deleção somente via backend (Admin SDK)
      allow create, delete: if false;
    }

    // ========================================================
    // PRODUCTS
    // Leitura pública: páginas de produto
    // Atualização autenticada: seller atualiza produto ativo/inativo
    // ========================================================
    match /products/{productId} {
      allow read: if true;
      allow update: if isAuthenticated();
      allow create, delete: if false;
    }

    // ========================================================
    // ORDERS
    // Criação apenas via backend (webhook/pagamento)
    // Leitura: seller lê por tenantId, comprador lê por email
    // Atualização: seller confirma PIX / atualiza status
    // ========================================================
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.customer.email == userEmail()
      );
      allow update: if isAuthenticated() && (
        resource.data.tenantId == request.auth.uid
      );
      allow create, delete: if false;
    }

    // ========================================================
    // ENROLLMENTS
    // Criação apenas via backend após pagamento confirmado
    // Leitura: comprador lê seus próprios acessos
    // ========================================================
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated() && (
        resource.data.customerEmail == userEmail() ||
        resource.data.tenantId == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // ========================================================
    // MODULES
    // Seller cria/edita/deleta módulos dos próprios produtos
    // Comprador (autenticado) lê para acessar área de membros
    // ========================================================
    match /modules/{moduleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ========================================================
    // LESSONS
    // Mesmo padrão que modules
    // ========================================================
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ========================================================
    // PROGRESS
    // Comprador registra progresso das próprias aulas
    // ========================================================
    match /progress/{progressId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ========================================================
    // REFUNDS
    // Criação via API backend; leitura pelo seller ou comprador
    // ========================================================
    match /refunds/{refundId} {
      allow read: if isAuthenticated() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.customerEmail == userEmail() ||
        resource.data.customerId == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // ========================================================
    // PHYSICAL SALES
    // Leitura pelo comprador pelo email
    // ========================================================
    match /physical_sales/{saleId} {
      allow read: if isAuthenticated()
                  && resource.data.customerEmail == userEmail();
      allow create, update, delete: if false;
    }

    // ========================================================
    // SUPPORT TICKETS
    // Seller abre e lê os próprios tickets; admin via backend
    // ========================================================
    match /supportTickets/{ticketId} {
      allow read: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isAuthenticated()
                    && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
      // clearAllSupportTickets() deleta via cliente — permitir para sellers autenticados
      allow delete: if isAuthenticated();
    }

    // ========================================================
    // SUPPORT MESSAGES
    // Seller envia mensagens via writeBatch() no cliente
    // ========================================================
    match /supportMessages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.senderId == request.auth.uid;
      allow update: if false;
      allow delete: if isAuthenticated();
    }

    // ========================================================
    // TUDO O MAIS: SOMENTE BACKEND (Admin SDK bypassa regras)
    // balances, commissions, affiliations, withdrawals,
    // paymentConfig, subscriptions, auditLogs, etc.
    // ========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
