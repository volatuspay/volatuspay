# ============================================================
# WHITE-LABEL GATEWAY — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Keys stored in Firebase (Firestore/RTDB) take priority
# over env vars — env vars are the fallback layer.
# NEVER commit .env to version control.
# ============================================================


# ── NODE ─────────────────────────────────────────────────────
NODE_ENV=production          # production | development
PORT=5000


# ── FIREBASE (Admin SDK — required) ──────────────────────────
# One of three formats is accepted (priority order below):

# Option A — single base64-encoded service account JSON
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=<base64 of service-account.json>

# Option B — raw JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option C — individual fields (most common in Replit)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/

# Admin SDK aliases (used as secondary fallback)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"


# ── WHITE-LABEL BRANDING (Frontend / VITE) ───────────────────
VITE_PLATFORM_NAME=My Gateway               # Name shown in UI and footer
VITE_PLATFORM_DOMAIN=yourdomain.com.br      # Production domain for checkout URLs
VITE_PLATFORM_CNPJ=                         # CNPJ shown in footer (optional)
VITE_SUPPORT_EMAIL=suporte@yourdomain.com   # Support email shown in footer
VITE_SUPPORT_WHATSAPP=5511999999999         # WhatsApp number (digits only)
VITE_ADMIN_EMAILS=admin@yourdomain.com      # Comma-separated admin emails
VITE_SOCIAL_INSTAGRAM=                      # Optional: https://www.instagram.com/yourpage/
VITE_SOCIAL_TWITTER=                        # Optional: https://x.com/yourpage
VITE_SOCIAL_LINKEDIN=                       # Optional: https://www.linkedin.com/company/yourcompany/


# ── FIREBASE (Frontend / VITE — required) ────────────────────
# These are exposed to the browser; they are NOT secrets.
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXX
VITE_FIREBASE_VAPID_KEY=                    # Firebase Cloud Messaging VAPID key


# ── ENCRYPTION ───────────────────────────────────────────────
# 32-byte hex master key used for AES-256-GCM encryption of
# all sensitive credentials stored in Firestore.
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=your-64-char-hex-key


# ── EFIBANK (PIX / Cartão BR) ────────────────────────────────
# Primary source: Admin → Vendas Globais (stored encrypted in Firestore).
# These env vars are the fallback when Firestore credentials are absent.

# Production credentials
EFI_CLIENT_ID=Client_Id_prod
EFI_CLIENT_SECRET=Client_Secret_prod
EFIBANK_CLIENT_ID=Client_Id_prod         # alias used by some routes
EFIBANK_CLIENT_SECRET=Client_Secret_prod

# Sandbox credentials (used only when EFIBANK_SANDBOX=true)
EFI_CLIENT_ID_SANDBOX=Client_Id_sandbox
EFI_CLIENT_SECRET_SANDBOX=Client_Secret_sandbox
EFIBANK_CLIENT_ID_SANDBOX=Client_Id_sandbox
EFIBANK_CLIENT_SECRET_SANDBOX=Client_Secret_sandbox

# Set to 'false' for production, 'true' for sandbox
EFIBANK_SANDBOX=false

# Account identifiers — obtain from your EfíBank dashboard
EFIBANK_PAYEE_CODE=your-payee-code       # identifies the receiving account for card SDK
EFIBANK_PIX_KEY=your-pix-key            # CPF / CNPJ / email / phone / random key
EFIBANK_ACCOUNT_CODE=your-account-code
EFIBANK_ACCOUNT_IDENTIFIER=your-account-identifier

# Webhook security — generate with: openssl rand -hex 32
EFIBANK_WEBHOOK_HMAC=your-webhook-hmac-secret
BOLETO_WEBHOOK_HMAC=your-boleto-webhook-hmac-secret

# P12 certificate password (if your .p12 is password-protected)
VOLATUS_SECRET_KEY=your-p12-cert-password


# ── STRIPE (cartão global) ────────────────────────────────────
# Primary source: Admin → Stripe Config (stored encrypted in Firestore).
# Live key prefix: sk_live_  →  environment auto-detected as production
# Test key prefix: sk_test_  →  environment auto-detected as sandbox
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
STRIPE_PUBLIC_KEY=pk_live_or_test_...    # alias
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
VITE_STRIPE_PUBLIC_KEY=pk_live_or_test_... # alias
STRIPE_WEBHOOK_SECRET=whsec_...          # from Stripe dashboard → Webhooks


# ── ADYEN (cartão alternativo) ───────────────────────────────
# Primary source: Admin → Adyen Config (stored encrypted in Firestore).
ADYEN_API_KEY=AQE...
ADYEN_CLIENT_KEY=test_...or live_...
ADYEN_MERCHANT_ACCOUNT=YourMerchantAccount
ADYEN_HMAC_KEY=your-adyen-hmac-key       # for webhook signature verification


# ── BUNNY CDN ────────────────────────────────────────────────
# Used for image/video uploads. Configure in Admin → Storage.
BUNNY_STORAGE_API_KEY=your-storage-api-key
BUNNY_STORAGE_ZONE_NAME=your-zone-name
BUNNY_STORAGE_REGION=br                  # br | de | sg | la | ny | se | uk
BUNNY_STREAM_API_KEY=your-stream-api-key
BUNNY_STREAM_LIBRARY_ID=123456


# ── RESEND (e-mail transacional) ─────────────────────────────
RESEND_API_KEY=re_...


# ── OPENAI (segurança / fraud detection) ─────────────────────
OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...   # alias used by AI security layer
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1


# ── LOGÍSTICA (opcional) ─────────────────────────────────────
CORREIOS_API_TOKEN=your-correios-token
CORREIOS_CONTRATO=your-contract-number
CORREIOS_DR=your-regional-direction-code
JADLOG_TOKEN=your-jadlog-token
JADLOG_CNPJ=00.000.000/0001-00
JADLOG_CONTA=your-jadlog-account
MELHOR_ENVIO_TOKEN=your-melhorenvio-token


# ── WEBHOOK HMAC SECRETS ─────────────────────────────────────
SUBSCRIPTION_WEBHOOK_HMAC=your-subscription-hmac
DELIVERY_WEBHOOK_HMAC=your-delivery-hmac
PAGARME_WEBHOOK_SECRET=your-pagarme-secret


# ── DEVELOPER / DEBUGGING ────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
SKIP_ENV_VALIDATION=false                # Set true only in emergencies
DISABLE_LOG_SANITIZATION=false          # Set true only for local debugging
FORCE_DEV_MODE=false
TENANT_DEBUG=false
ALLOW_REPLIT_IPS=true                   # Allow Replit health-check IPs
